###############################################################################
# TG Vault 环境配置文件模板 (Environment Configuration Template)
# 说明：请复制此文件为 .env 并根据实际部署环境进行修改
###############################################################################

# =============================================================================
# 必填：部署前请先修改
# =============================================================================

# PostgreSQL 数据库密码
DB_PASSWORD=your_secure_password_here

# 前端访问后端的 API 地址，必须包含协议
# 示例：Nginx/Caddy 将 api.example.com 反代到宿主机 51947 端口
VITE_API_URL=https://api.example.com

# 允许跨域的前端来源地址，通常填写前端网页完整地址
# 示例：Nginx/Caddy 将 cloud.example.com 反代到宿主机 47832 端口
CORS_ORIGIN=https://cloud.example.com

# 应用主域名，不带 http/https，用于生成链接和展示
DOMAIN=cloud.example.com

# =============================================================================
# 可选：Cloudflare Tunnel（无需公网端口/证书，直接暴露服务）
# =============================================================================

# 启用方式：取消注释以下两行，并在 Cloudflare Zero Trust 面板创建 Tunnel，
# 将公共主机名（如 cloud.example.com）指向 http://frontend:80
# COMPOSE_PROFILES=cloudflared
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# =============================================================================
# 可选：Telegram 集成
# =============================================================================

# Telegram Bot 基础配置。只要填这三项，Bot 就可以收文件、管理任务、调用 yt-dlp。
# TELEGRAM_API_ID / TELEGRAM_API_HASH 也会被账号级下载器复用，不需要再配置 USER_API_ID / USER_API_HASH。
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# 可选：账号级 Telegram 下载器 session 文件路径。
# 不生成 session 时，Bot 基础功能仍可用；但频道/群组批量抓取、订阅同步、
# 以及超过 Bot 限制的大文件下载会受限。
# 生成命令：docker compose run --rm --no-deps backend npm run login:telegram-user
TELEGRAM_USER_SESSION_FILE=/data/telegram_user_session.txt

# Telegram 并发下载 worker 数。单请求上限仍是 512KB；该值控制单个文件内部的并发分片请求数，建议 4-8，最大 16。
TELEGRAM_DOWNLOAD_WORKERS=4

# Telegram 文件级下载并发数：一次最多同时下载几个文件。可在 Bot 里用 /file_concurrency 调整。
TELEGRAM_FILE_DOWNLOAD_CONCURRENCY=2

# =============================================================================
# 可选：yt-dlp 视频下载
# =============================================================================

# yt-dlp 可执行文件路径（默认使用系统 PATH；仅在找不到命令时再改为绝对路径）
YTDLP_BIN=yt-dlp
# yt-dlp 下载工作目录
YTDLP_WORK_DIR=./data/uploads/ytdlp
# yt-dlp 下载任务并发
YTDLP_MAX_CONCURRENT=1

# =============================================================================
# 默认配置：通常无需修改
# =============================================================================

# 后端服务运行端口
PORT=51947

# 文件与缓存目录（容器内路径）
UPLOAD_DIR=/data/uploads
THUMBNAIL_DIR=/data/thumbnails
CHUNK_DIR=/data/chunks

# 重复文件策略：copy=生成副本，skip=跳过重复（同名+同目录+同大小）
DUPLICATE_FILE_MODE=copy

# 是否自动清理本地 uploads 中未登记到数据库的孤儿文件。默认开启，可在 Bot 里用 /cleanup_settings 关闭。
AUTO_CLEANUP_ORPHANS=true

# Telegram Bot 限流：普通消息每分钟 30 次；重型命令每 10 分钟 5 次
TELEGRAM_RATE_WINDOW_MS=60000
TELEGRAM_RATE_MAX=30
TELEGRAM_HEAVY_RATE_WINDOW_MS=600000
TELEGRAM_HEAVY_RATE_MAX=5

# 安全与上传限制
# TRUST_PROXY：Express trust proxy 设置。uniquelocal 信任私有网段（容器网络/宿主机反代均适用）；
# 仅当后端直接暴露公网时才需要收紧为 loopback
TRUST_PROXY=uniquelocal
COOKIE_SECURE=true
JSON_BODY_LIMIT=2mb
MAX_UPLOAD_CHUNK_MB=64
MAX_UPLOAD_SESSIONS=200
MAX_TOTAL_CHUNKS=50000
ORPHAN_CLEANUP_MIN_AGE_MS=600000

# Telegram 状态调试日志（排查 Bot 消息刷新问题时再启用/查看）
TG_STATUS_DEBUG_LOG=/data/logs/tg_silent_debug.log
TG_DEBUG_LOG_MAX_MB=5
